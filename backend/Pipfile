[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
blinker = "==1.9.0"
click = "==8.3.1"
itsdangerous = "==2.2.0"
jinja2 = "==3.1.6"
markupsafe = "==3.0.3"
sqlalchemy = "==2.0.48"
werkzeug = "==3.1.7"
flask = "*"
flask-sqlalchemy = "*"
flask-cors = "*"
flask-migrate = "*"
python-dotenv = "*"
psycopg2-binary = "*"
flask-jwt-extended = "*"

[dev-packages]

[requires]
python_version = "3.13"

[scripts]
start = "flask --app app run --debug"
initdb = "flask --app app db init"
migrate = "flask --app app db migrate -m 'update'"
upgrade = "flask --app app db upgrade"
